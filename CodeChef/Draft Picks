import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s=new Scanner(System.in);
		int t=s.nextInt();
		while(t-->0){
		    int n=s.nextInt();
		    int k=s.nextInt();
		    int a[]=new int[n];
	        int x=0,i=0;
		    while(k>0){
		        if(x==0){
		          i=0;
		        while(i<n && k>0){
                   a[i]+=k;
                   k--;
                   i++;
		        }
		        x=1;
		        }
		        else{
		            i=n-1;
		        while(i>=0 && k>0){
		            a[i]+=k;
		            k--;
		            i--;
		        }
		        x=0;
		        }
		    }
		   int m=Integer.MIN_VALUE;
		    for(int j=0;j<n;j++){
		        m=Math.max(m,a[j]);
		    }
		    System.out.println(m);
		}
	}
}
